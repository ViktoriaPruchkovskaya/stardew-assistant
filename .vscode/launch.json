{
    "configurations": [
        {
            "name": "uv run",
            "type": "debugpy",
            "request": "launch",
            "program": "main.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/app",
        },
        {
            "name": "uv run crawler",
            "type": "debugpy",
            "request": "launch",
            "program": "wiki_crawler.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/app",
            "envFile": "${workspaceFolder}/app/.env"
        },
        {
            "command": "pnpm start",
            "name": "Run pnpm start",
            "request": "launch",
            "type": "node-terminal",
            "cwd": "${workspaceFolder}/web",
        },
        {
            "name": "uv run rag",
            "type": "debugpy",
            "request": "launch",
            "module": "rag_pipeline.main",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}/app",
            "envFile": "${workspaceFolder}/app/.env"
        }
    ]
}